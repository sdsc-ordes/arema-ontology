.ch/Opening","prefLabel":{"en":"Opening","de":"Offnung"},"definition":{"en":"Openings in walls such as doors and windows"},"narrower":[{"id":"https://ontology.atlas-regenmat.ch/Door","prefLabel":{"en":"Door","de":"Tür"},"definition":{"en":"A door is a structure to enter or exit a room"}},{"id":"https://ontology.atlas-regenmat.ch/Window","prefLabel":{"en":"Window","de":"Fenster"},"definition":{"en":"A window is a structure to let light or air into a room"}}]},{"id":"https://ontology.atlas-regenmat.ch/ExteriorThermalInsulation","prefLabel":{"en":"Ext. Thermal Insulation","de":"Aussenwärmedämmung"},"definition":{"en":"External Thermal Insulation"}},{"id":"https://ontology.atlas-regenmat.ch/ExteriorWallFinishingAboveGround","prefLabel":{"en":"Ext. Wall Finishing Above Ground","de":"Fassadenbekleidung"},"definition":{"en":"Facade finishing above ground"}},{"id":"https://ontology.atlas-regenmat.ch/ExteriorWallFinishingBasement","prefLabel":{"en":"Ext. Wall Finishing Under Ground","de":"Äussere Beschichtung Unter Terrain"},"definition":{"en":"External wall finishing under ground"}},{"id":"https://ontology.atlas-regenmat.ch/RoofCovering","prefLabel":{"en":"Roof Covering","de":"Bedachung"},"definition":{"en":"Roof Covering"}},{"id":"https://ontology.atlas-regenmat.ch/SunWeatherProtection","prefLabel":{"en":"Sun & Weather Protection","de":"Sonnen- & Wetterschutz"},"definition":{"en":"Sun & Weather Protection"}}]},{"id":"https://ontology.atlas-regenmat.ch/Other","prefLabel":{"en":"Other","de":"Andere","fr":"Autre"},"definition":{"en":"Elements other than structure, finishing or envelope"},"narrower":[{"id":"https://ontology.atlas-regenmat.ch/TechnicalEquipement","prefLabel":{"en":"Technical Equipement","de":"Technik"},"definition":{"en":"Technical Equipement such as Heating, Ventilation, Water or electricity supply"}}]}]}]}],"@context":{"@version":1.1,"id":"@id","type":"@type","@vocab":"http://www.w3.org/2004/02/skos/core#","xsd":"http://www.w3.org/2001/XMLSchema#","rdfs":"htt